# Google Gemini API Key (required for Budget Draft)
GEMINI_API_KEY=your_gemini_api_key_here

# e-Stat API Key (optional, for higher rate limits)
ESTAT_API_KEY=

# Target area (default: Tokyo Chiyoda-ku)
TARGET_AREA_NAME=東京都千代田区
TARGET_AREA_CODE=13101

# Server settings
API_HOST=localhost
API_PORT=8000
